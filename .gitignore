target/

# AIDA distributed store (orphan branch worktree)
.aida-store/

# Learner's working dir — every reset wipes it
workspace/

# Session worktrees `aida session start` creates as siblings of
# workspace/ in exercises 27-30. `aida-tutor reset` cleans these up.
# trace:STORY-28
workspace-*/

# Per-learner progress (gitignored: each learner's own state)
.aida-tutor-progress.toml

# AIDA runtime state — deny-by-default, only config.toml is tracked.
# Catches cache.db*, sessions/, session-env.sh, and any future runtime
# file AIDA writes here, so `aida session end` never trips on an
# untracked .aida/ path.
.aida/*
!.aida/config.toml
